config {
  type: "view",
  schema: "BQ_PFU_INCIPY"
}

SELECT
    b.*

  FROM ${ref("atenea_purchases")} e
  JOIN ${ref("pre_event")} b
    ON e.user_pseudo_id = b.user_pseudo_id
  WHERE b.event_timestamp <= e.purchase_timestamp  
  AND b.event_timestamp >= e.purchase_timestamp - 365 * 24 * 60 * 60 * 1000000