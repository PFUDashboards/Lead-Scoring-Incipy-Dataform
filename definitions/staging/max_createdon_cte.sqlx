
config {
  type: "view",
  schema: "BQ_PFU_INCIPY"
}

--RESTAMOS 30 DIAS DE ATENEA UN TIEMPO QUE CONSIDERAMOS PARA QUE EL LEAD DECIDE SI HACE MATRICULA
SELECT
    UNIX_MICROS(
      TIMESTAMP_SUB(
        TIMESTAMP_MICROS(MAX(ld_timestamp)),
        INTERVAL 30 DAY
      )
    ) AS max_createdon
FROM ${ref("pre_atenea")}